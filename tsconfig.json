{
    "compilerOptions": {
        "lib": [
            "es5",
            "es6",
            "DOM"
        ],
        "target": "es5",
        "typeRoots": [
            "./src/modules",
            "./node_modules/@types",
        ],
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "./build",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "esModuleInterop": true
    }
}